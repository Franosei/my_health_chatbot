OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Required (Postgres). Local dev: docker compose up -d db, then
# postgresql+psycopg://flynnmed:flynnmed_dev_only@localhost:5432/flynnmed
DATABASE_URL=

# Required in production (ENVIRONMENT=production) -- app refuses to start
# without it. In development, an ephemeral random secret is used if unset
# (sessions won't survive a restart).
JWT_SECRET_KEY=
ENVIRONMENT=development


SMTP_HOST=smtp.gmail.com
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=